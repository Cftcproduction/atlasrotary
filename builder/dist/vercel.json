{
  "cleanUrls": true,
  "trailingSlash": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/about.html",
      "destination": "/about/",
      "permanent": true
    },
    {
      "source": "/team.html",
      "destination": "/team/",
      "permanent": true
    },
    {
      "source": "/projects.html",
      "destination": "/projects/",
      "permanent": true
    },
    {
      "source": "/presentation.html",
      "destination": "/presentation/",
      "permanent": true
    },
    {
      "source": "/contact.html",
      "destination": "/contact/",
      "permanent": true
    },
    {
      "source": "/events.html",
      "destination": "/events/",
      "permanent": true
    },
    {
      "source": "/events-detail.html",
      "destination": "/events/",
      "permanent": true
    }
  ]
}